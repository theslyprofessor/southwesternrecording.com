---
import PageLayout from "@/layouts/PageLayout.astro";
import { Card, CardHeader, CardTitle, CardDescription, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import {
  SITE_CONFIG,
  PROGRAM_HIGHLIGHTS,
  FACILITIES,
  COURSES,
  DEGREES,
  FACULTY,
  STUDENT_SUCCESS,
  PROGRAM_INFO
} from "@/lib/constants";
import {
  Mic2,
  Users,
  Award,
  DollarSign,
  ArrowRight,
  CheckCircle,
  Music,
  Radio,
  Headphones,
  Volume2,
  MapPin,
  Mail,
  GraduationCap,
  Quote,
  Instagram,
  Building,
  Calendar,
  Handshake,
  ExternalLink,
  Monitor,
  Sliders
} from "lucide-react";

const iconMap = {
  Mic2,
  Users,
  Award,
  DollarSign,
};
---

<PageLayout>
  <!-- Hero Section -->
  <section class="gradient-hero min-h-screen flex items-center pt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <Badge variant="outline" className="mb-6">
            Chula Vista, CA
          </Badge>
          <p class="text-lg font-semibold text-primary tracking-wide uppercase mb-2">
            Southwestern College
          </p>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
            <span class="gradient-text">Center for</span>
            <br />
            <span class="text-foreground">Recording Arts</span>
            <br />
            <span class="text-foreground">&amp; Technology</span>
          </h1>
          <p class="text-xl text-muted-foreground mb-4">
            Professional Audio Education in San Diego
          </p>
          <p class="text-lg text-muted-foreground mb-8 max-w-xl">
            Launch your career in audio engineering, music production, and sound design.
            Train on world-class equipment in studios designed for hands-on learning.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#contact"
              class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-md font-semibold hover:bg-primary/90 transition-colors"
            >
              Apply Now
              <ArrowRight className="h-5 w-5" />
            </a>
            <a
              href="#collaborate"
              class="inline-flex items-center justify-center gap-2 border border-input bg-card px-8 py-4 rounded-md font-semibold hover:bg-secondary transition-colors"
            >
              Book a Session
            </a>
          </div>
        </div>

        <!-- Hero Image: Studio A -->
        <div class="hidden lg:block">
          <div class="photo-frame aspect-[4/3]">
            <img
              src="/images/studio-a-mic-shootout.jpg"
              alt="Studio A Control Room at the Center for Recording Arts & Technology featuring SSL Duality SE console"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Program Overview Section -->
  <section id="program" class="py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="secondary" className="mb-4">
          Program Overview
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Why Southwestern Recording?
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Our Recording Arts & Technology program combines technical excellence with creative expression,
          preparing you for a successful career in the audio industry.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
        {PROGRAM_HIGHLIGHTS.map((highlight) => {
          const Icon = iconMap[highlight.icon as keyof typeof iconMap];
          return (
            <div class="p-6 rounded-xl bg-card border border-border card-hover">
              <div class="inline-flex p-3 rounded-full bg-primary/10 text-primary mb-4">
                <Icon className="h-6 w-6" />
              </div>
              <h3 class="font-semibold text-lg mb-2">{highlight.title}</h3>
              <p class="text-muted-foreground text-sm">{highlight.description}</p>
            </div>
          );
        })}
      </div>

      <!-- Degrees & Certificates -->
      <div class="bg-card rounded-2xl p-8 border border-border">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="md:col-span-2">
            <div class="flex items-center gap-2 mb-4">
              <GraduationCap className="h-6 w-6 text-primary" />
              <h3 class="font-semibold text-lg">Degrees & Certificates</h3>
            </div>
            <ul class="space-y-3">
              {DEGREES.map((degree) => (
                <li class="flex items-start gap-2">
                  <CheckCircle className="h-4 w-4 text-accent shrink-0 mt-1" />
                  <div>
                    {degree.url ? (
                      <a
                        href={degree.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-foreground hover:text-primary transition-colors font-medium"
                      >
                        {degree.name}
                        <ArrowRight className="inline h-3 w-3 ml-1" />
                      </a>
                    ) : (
                      <span class="text-foreground font-medium">{degree.name}</span>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
          <div class="space-y-6">
            <div>
              <h3 class="font-semibold text-lg mb-2">Program Duration</h3>
              <p class="text-muted-foreground">{PROGRAM_INFO.duration}</p>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-2">Total Units</h3>
              <p class="text-muted-foreground">{PROGRAM_INFO.totalUnits} units</p>
            </div>
            <div>
              <h3 class="font-semibold text-lg mb-2">Format</h3>
              <p class="text-muted-foreground">{PROGRAM_INFO.format}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Facilities Section -->
  <section id="facilities" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="secondary" className="mb-4">
          State-of-the-Art
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Five Professional Studios
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Train on industry-standard equipment across five studios, from our flagship SSL room to dedicated electronic music production suites.
        </p>
      </div>

      <!-- Studio A Feature with Photo -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <div class="photo-frame aspect-[16/10]">
          <img
            src="/images/studio-a-control-room-hq.webp"
            alt="Studio A Control Room with SSL Duality SE console"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col justify-center">
          <h3 class="font-bold text-2xl mb-3">Studio A &mdash; Control Room</h3>
          <p class="text-muted-foreground mb-4">
            Our flagship recording space features an SSL Duality SE console, Pro Tools HDX, and a full complement of outboard processing. Designed for professional tracking, mixing, and mastering.
          </p>
          <div class="flex flex-wrap gap-2">
            {FACILITIES[0].features.map((feature) => (
              <Badge variant="secondary" className="text-xs">
                {feature}
              </Badge>
            ))}
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        <div class="flex flex-col justify-center order-2 lg:order-1">
          <h3 class="font-bold text-2xl mb-3">Studio A &mdash; Tracking Room</h3>
          <p class="text-muted-foreground mb-4">
            A spacious live room with world-class acoustics, hardwood floors, and room for a full ensemble. Features a grand piano, isolation booths, and high ceilings for natural ambience.
          </p>
          <div class="flex flex-wrap gap-2">
            {FACILITIES[1].features.map((feature) => (
              <Badge variant="secondary" className="text-xs">
                {feature}
              </Badge>
            ))}
          </div>
        </div>
        <div class="photo-frame aspect-[16/10] order-1 lg:order-2">
          <img
            src="/images/studio-a-tracking-room-hq.webp"
            alt="Studio A Tracking Room with hardwood floors and grand piano"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Studios B through E -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {FACILITIES.slice(2).map((facility, index) => (
          <div class="group relative overflow-hidden rounded-2xl bg-background border border-border p-8 card-hover">
            <div class="absolute top-0 left-0 w-full h-1 vu-accent opacity-50 group-hover:opacity-100 transition-opacity"></div>
            <div class="flex items-start gap-4">
              <div class="p-3 rounded-xl bg-primary/10">
                {index === 0 && <Radio className="h-6 w-6 text-primary" />}
                {index === 1 && <Monitor className="h-6 w-6 text-primary" />}
                {index === 2 && <Sliders className="h-6 w-6 text-primary" />}
              </div>
              <div class="flex-1">
                <h3 class="font-semibold text-xl mb-2">{facility.name}</h3>
                <p class="text-muted-foreground mb-4">{facility.description}</p>
                <div class="flex flex-wrap gap-2">
                  {facility.features.map((feature) => (
                    <Badge variant="secondary" className="text-xs">
                      {feature}
                    </Badge>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- History Section -->
  <section id="history" class="py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="secondary" className="mb-4">
          Our Story
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          A Legacy of Excellence
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          From a vision to train the next generation of audio professionals to a world-class facility serving the San Diego community.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Jay Henry Photo -->
        <div class="photo-frame aspect-[4/3]">
          <img
            src="/images/jay-henry-hq.jpg"
            alt="Jay Henry, founder of the Center for Recording Arts & Technology at Southwestern College"
            loading="lazy"
          />
        </div>

        <!-- History Content -->
        <div>
          <div class="space-y-8">
            <div>
              <div class="flex items-center gap-3 mb-3">
                <Building className="h-6 w-6 text-primary" />
                <h3 class="font-bold text-xl">The Beginning</h3>
              </div>
              <p class="text-muted-foreground">
                In <strong class="text-foreground">2007</strong>, the Center for Recording Arts & Technology (CRAT) was inaugurated at Southwestern College under the vision and leadership of <strong class="text-foreground">Jay Henry</strong>, a Grammy-nominated engineer and producer. The state invested <strong class="text-foreground">$6.5 million</strong> to build a facility that would rival professional studios anywhere in the world. Jay passed away in <strong class="text-foreground">2020</strong>, but his legacy lives on through the program he built and the students it continues to inspire.
              </p>
            </div>

            <div>
              <div class="flex items-center gap-3 mb-3">
                <Music className="h-6 w-6 text-primary" />
                <h3 class="font-bold text-xl">World-Class Facilities</h3>
              </div>
              <p class="text-muted-foreground">
                The investment created five recording studios, production labs, and mastering suites equipped with the same gear used by top professionals. The facility was designed from the ground up for education, with acoustics by studio designers and equipment from SSL, Avid, and more.
              </p>
            </div>

            <div>
              <div class="flex items-center gap-3 mb-3">
                <Users className="h-6 w-6 text-primary" />
                <h3 class="font-bold text-xl">Community Impact</h3>
              </div>
              <p class="text-muted-foreground">
                Since opening, the program has trained hundreds of audio professionals who now work across the music, film, podcast, and live event industries. Located in Chula Vista, the program serves one of the most diverse communities in Southern California, making professional audio education accessible to all.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Courses Section -->
  <section id="courses" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="outline" className="mb-4">
          Curriculum
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Courses & Curriculum
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          From music technology fundamentals to professional work experience, our curriculum covers all aspects of modern audio production.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {COURSES.map((course) => (
          <Card className="card-hover">
            <CardHeader>
              <div class="flex items-center justify-between mb-2">
                <Badge
                  variant={course.level === "Beginner" ? "secondary" : course.level === "Intermediate" ? "default" : "accent"}
                  className="text-xs"
                >
                  {course.level}
                </Badge>
                <span class="text-xs text-muted-foreground font-mono">{course.units} units</span>
              </div>
              <CardTitle className="text-lg">{course.title}</CardTitle>
              <p class="text-xs text-muted-foreground font-mono mt-1">
                {course.id}
                {course.crosslisted && <span class="text-muted-foreground/70"> / {course.crosslisted}</span>}
              </p>
            </CardHeader>
            <CardContent>
              <CardDescription>{course.description}</CardDescription>
            </CardContent>
          </Card>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a
          href="https://catalog.swccd.edu/associate-degree-certificate-programs/recording-arts-technology/recording-arts-technology-as/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-primary hover:underline font-medium"
        >
          View full degree plan in the SWC catalog
          <ArrowRight className="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>

  <!-- Faculty Section -->
  <section id="faculty" class="py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="secondary" className="mb-4">
          Our Team
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          Meet Our Faculty
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Learn from experienced professionals who bring real-world industry knowledge to the classroom.
        </p>
      </div>

      <div class="max-w-md mx-auto">
        {FACULTY.map((member) => (
          <div class="text-center bg-card rounded-2xl p-8 border border-border card-hover">
            {member.image ? (
              <img
                src={member.image}
                alt={member.name}
                class="w-32 h-32 rounded-full mx-auto mb-6 object-cover border-4 border-primary/20"
                loading="lazy"
              />
            ) : (
              <div class="w-32 h-32 rounded-full bg-gradient-to-br from-primary/10 to-accent/10 mx-auto mb-6 flex items-center justify-center border-4 border-primary/20">
                <span class="text-3xl font-bold gradient-text">
                  {member.name.split(' ').map(n => n[0]).join('')}
                </span>
              </div>
            )}
            <h3 class="font-semibold text-lg">{member.name}</h3>
            <p class="text-primary font-medium mb-2">{member.title}</p>
            <p class="text-muted-foreground text-sm">{member.bio}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Student Success Section -->
  <section id="success" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <Badge variant="secondary" className="mb-4">
          Student Voices
        </Badge>
        <h2 class="text-3xl sm:text-4xl font-bold mb-4">
          What Our Students Say
        </h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">
          Hear from graduates who launched their careers through the Recording Arts & Technology program.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {STUDENT_SUCCESS.map((student) => (
          <div class="bg-background rounded-2xl p-8 border border-border relative">
            <Quote className="absolute top-6 right-6 h-8 w-8 text-primary/15" />
            <p class="text-foreground italic mb-6 text-lg leading-relaxed">
              &ldquo;{student.quote}&rdquo;
            </p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-primary/10 to-accent/10 flex items-center justify-center">
                <GraduationCap className="h-5 w-5 text-primary" />
              </div>
              <div>
                <p class="font-medium text-sm">{student.name}</p>
                <p class="text-xs text-muted-foreground">Class of {student.year}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Come Work With Us / Collaboration Section -->
  <section id="collaborate" class="py-24 bg-background">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <Badge variant="secondary" className="mb-4">
            Community
          </Badge>
          <h2 class="text-3xl sm:text-4xl font-bold mb-4">
            Come Work With Us
          </h2>
          <p class="text-muted-foreground text-lg mb-6">
            We believe great music is made through collaboration. Our studios are open to the community &mdash; whether you're an independent artist, band, podcaster, or creative professional looking for a world-class space to bring your project to life.
          </p>
          <p class="text-muted-foreground mb-8">
            Book a session in our studios and work alongside our students and faculty. It's a chance to access professional-grade facilities while supporting the next generation of audio engineers.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <a
              href={SITE_CONFIG.bookingFormUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-md font-semibold hover:bg-primary/90 transition-colors"
            >
              Book a Session
              <ExternalLink className="h-5 w-5" />
            </a>
            <a
              href={SITE_CONFIG.instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 border border-input bg-card px-8 py-4 rounded-md font-semibold hover:bg-secondary transition-colors"
            >
              <Instagram className="h-5 w-5" />
              @{SITE_CONFIG.instagram}
            </a>
          </div>
        </div>

        <!-- What to expect -->
        <div class="bg-card rounded-2xl p-8 border border-border">
          <h3 class="text-xl font-semibold mb-6">What to Expect</h3>
          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="p-2 rounded-lg bg-primary/10 text-primary shrink-0">
                <Mic2 className="h-5 w-5" />
              </div>
              <div>
                <h4 class="font-medium mb-1">Professional Studio Access</h4>
                <p class="text-muted-foreground text-sm">
                  Record in Studio A with SSL Duality SE console, Pro Tools HDX, and a world-class microphone collection.
                </p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="p-2 rounded-lg bg-primary/10 text-primary shrink-0">
                <Users className="h-5 w-5" />
              </div>
              <div>
                <h4 class="font-medium mb-1">Student & Faculty Support</h4>
                <p class="text-muted-foreground text-sm">
                  Our students gain real-world experience by assisting sessions, and faculty provide guidance throughout.
                </p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="p-2 rounded-lg bg-primary/10 text-primary shrink-0">
                <Handshake className="h-5 w-5" />
              </div>
              <div>
                <h4 class="font-medium mb-1">Community Collaboration</h4>
                <p class="text-muted-foreground text-sm">
                  We welcome musicians, vocalists, producers, and podcasters from across San Diego and beyond.
                </p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="p-2 rounded-lg bg-primary/10 text-primary shrink-0">
                <Calendar className="h-5 w-5" />
              </div>
              <div>
                <h4 class="font-medium mb-1">Flexible Scheduling</h4>
                <p class="text-muted-foreground text-sm">
                  Fill out our booking form and we'll work with you to find the right time for your session.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact / Admissions Section -->
  <section id="contact" class="py-24 bg-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <Badge variant="outline" className="mb-4">
            Get in Touch
          </Badge>
          <h2 class="text-3xl sm:text-4xl font-bold mb-6">
            Ready to Record Your Future?
          </h2>
          <p class="text-muted-foreground text-lg mb-8">
            Take the first step toward your career in audio. Apply to Southwestern College's
            Recording Arts & Technology program today, or reach out with any questions.
          </p>

          <div class="space-y-4 mb-8">
            <div class="flex items-center gap-3">
              <div class="p-2 rounded-lg bg-primary/10 text-primary">
                <Mail className="h-5 w-5" />
              </div>
              <a href={`mailto:${SITE_CONFIG.email}`} class="text-foreground hover:text-primary transition-colors">
                {SITE_CONFIG.email}
              </a>
            </div>
            <div class="flex items-center gap-3">
              <div class="p-2 rounded-lg bg-primary/10 text-primary">
                <Instagram className="h-5 w-5" />
              </div>
              <a href={SITE_CONFIG.instagramUrl} target="_blank" rel="noopener noreferrer" class="text-foreground hover:text-primary transition-colors">
                @{SITE_CONFIG.instagram}
              </a>
            </div>
            <div class="flex items-start gap-3">
              <div class="p-2 rounded-lg bg-primary/10 text-primary">
                <MapPin className="h-5 w-5" />
              </div>
              <div>
                <p class="text-foreground">Southwestern College</p>
                <p class="text-muted-foreground text-sm">{SITE_CONFIG.address}</p>
              </div>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="https://www.swccd.edu/admissions"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-primary text-primary-foreground px-8 py-4 rounded-md font-semibold hover:bg-primary/90 transition-colors"
            >
              Apply to Southwestern
              <ArrowRight className="h-5 w-5" />
            </a>
            <a
              href="https://www.swccd.edu/campus-visit"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 border border-input bg-background px-8 py-4 rounded-md font-semibold hover:bg-secondary transition-colors"
